# ---------------------------------------------------------------------------
# Jira connection
# ---------------------------------------------------------------------------

# Base URL of the internal Jira 8 instance (no trailing slash)
JIRA_BASE_URL=https://jira.yourcompany.com

# REST API path used to validate that the session is still alive.
# Jira 8 uses /rest/api/2/myself — returns 200 for authenticated users.
JIRA_VALIDATE_PATH=/rest/api/2/myself

# Local file path for persisted Playwright browser storage state (cookies)
JIRA_SESSION_FILE=.jira/session.json

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Playwright (used for SSO login bootstrap only)
# ---------------------------------------------------------------------------

# Set to true to run in headless mode.
# Keep false for SSO — most corporate IdPs block headless browsers.
PLAYWRIGHT_HEADLESS=false

# Browser engine: chromium | firefox | webkit
PLAYWRIGHT_BROWSER=chromium

# ---------------------------------------------------------------------------
# Attachment security
# ---------------------------------------------------------------------------

# Directory where downloaded attachments are saved (created if missing)
# Example: ATTACHMENT_WORKSPACE=/home/user/projects/my-app
ATTACHMENT_WORKSPACE=./downloads
