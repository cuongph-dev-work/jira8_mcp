{
  "name": "jira-run-mcp",
  "version": "0.1.0",
  "description": "MCP server for internal Jira 8 via SSO session bootstrap with Playwright",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "jira-mcp": "dist/server.js",
    "jira-auth-login": "dist/cli/auth-login.js",
    "jira-auth-check": "dist/cli/auth-check.js",
    "jira-auth-clear": "dist/cli/auth-clear.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit false --outDir dist",
    "prepare": "npm run build && chmod +x dist/server.js dist/cli/auth-login.js dist/cli/auth-check.js dist/cli/auth-clear.js",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "jira-auth-login": "tsx src/cli/auth-login.ts",
    "jira-auth-check": "tsx src/cli/auth-check.ts",
    "jira-auth-clear": "tsx src/cli/auth-clear.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "axios": "^1.7.7",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.5",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.48.2",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
